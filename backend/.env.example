REDIS_URL=redis://redis:6379/0
OUTPUT_DIR=/data/outputs
PUBLIC_OUTPUT_BASE=/outputs
API_BASE_PATH=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
GENERATOR_MODE=openai_image
GENERATOR_TIMEOUT_SECONDS=60
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_MODERATION=auto
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
HF_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
HF_DEVICE=mps
HF_NUM_INFERENCE_STEPS=30
HF_GUIDANCE_SCALE=7.0
HF_IMAGE_STRENGTH=0.45
MANNEQUIN_TEMPLATE_IMAGE=backend/assets/egmusc.webp
